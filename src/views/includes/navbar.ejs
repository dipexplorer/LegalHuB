<header>
  <nav class="legalhub-nav" id="mainNav">
    <div class="nav-container">
      <div class="nav-brand">
        <a href="/" class="brand-link">
          <span class="brand-icon">⚖️</span>
          <span class="brand-text">Legal<span class="brand-accent">HuB</span></span>
        </a>
      </div>

      <ul class="nav-links" id="navLinks">
        <li><a href="/dictionary" class="nav-link"><span class="link-icon">📖</span> Dictionary</a></li>
        <li><a href="/articles" class="nav-link"><span class="link-icon">📰</span> Articles</a></li>
        <li><a href="/documents" class="nav-link"><span class="link-icon">📋</span> Documents</a></li>
        <li><a href="/rights" class="nav-link"><span class="link-icon">🛡️</span> Rights</a></li>
        <li><a href="/lawyers" class="nav-link"><span class="link-icon">👨‍⚖️</span> Lawyers</a></li>
        <li><a href="/about" class="nav-link"><span class="link-icon">ℹ️</span> About</a></li>
      </ul>

      <div class="nav-actions">
        <% if (currentUser) { %>
          <div class="notifications-wrapper" id="notificationsWrapper">
            <button class="icon-btn notification-btn" id="notificationToggle" aria-label="Notifications">
              <span class="icon">🔔</span>
              <% if (notificationsCount && notificationsCount > 0) { %>
                <span class="notification-badge"><%= notificationsCount %></span>
              <% } %>
            </button>
            <div class="notifications-dropdown" id="notificationsDropdown">
              <div class="dropdown-header">
                <span>Notifications</span>
              </div>
              <div class="notifications-list">
                <% if (notifications && notifications.length > 0) { %>
                  <% notifications.slice(0, 5).forEach(n => { %>
                    <a href="/notifications" class="notification-item <%= n.status === 'unread' ? 'unread' : '' %>">
                      <div class="notification-icon">🔔</div>
                      <div class="notification-content">
                        <span class="notification-title"><%= n.title %></span>
                        <span class="notification-time"><%= new Date(n.createdAt).toLocaleDateString() %></span>
                      </div>
                    </a>
                  <% }) %>
                <% } else { %>
                  <div class="empty-notifications">No notifications</div>
                <% } %>
              </div>
              <a href="/notifications" class="dropdown-footer">View all notifications</a>
            </div>
          </div>

          <div class="profile-wrapper" id="profileWrapper">
            <button class="profile-btn" id="profileToggle" aria-label="Profile Menu">
              <img src="<%= currentUser.profilePicture || '/pic/profile.jpg' %>" alt="Profile" class="profile-img" />
              <span class="profile-name"><%= currentUser.username %></span>
              <span class="dropdown-arrow">▼</span>
            </button>
            <div class="profile-dropdown" id="profileDropdown">
              <div class="dropdown-user">
                <img src="<%= currentUser.profilePicture || '/pic/profile.jpg' %>" alt="Profile" class="dropdown-avatar" />
                <div class="dropdown-user-info">
                  <span class="dropdown-username"><%= currentUser.username %></span>
                  <span class="dropdown-email"><%= currentUser.email %></span>
                </div>
              </div>
              <div class="dropdown-divider"></div>
              <a href="/account" class="dropdown-item"><span class="item-icon">👤</span> My Profile</a>
              <a href="/appointments" class="dropdown-item"><span class="item-icon">📅</span> My Appointments</a>
              <a href="/settings" class="dropdown-item"><span class="item-icon">⚙️</span> Settings</a>
              <div class="dropdown-divider"></div>
              <a href="/api/users/logout" class="dropdown-item logout"><span class="item-icon">🚪</span> Logout</a>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="btn btn-secondary btn-sm">Login</a>
          <a href="/register" class="btn btn-primary btn-sm">Sign Up</a>
        <% } %>

        <button class="hamburger" id="hamburger" aria-label="Toggle Menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  .legalhub-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: linear-gradient(135deg, #0f1322 0%, #1a1a2e 50%, #16213e 100%);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(108, 99, 255, 0.2);
    transition: all 0.3s ease;
  }

  .legalhub-nav.scrolled {
    background: rgba(15, 19, 34, 0.95);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 30px;
    gap: 40px;
  }

  .nav-brand {
    flex-shrink: 0;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #fff;
  }

  .brand-icon {
    font-size: 1.8rem;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .brand-text {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .brand-accent {
    color: #6c63ff;
    background: linear-gradient(135deg, #6c63ff, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 10px;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-link:hover {
    color: #fff;
    background: rgba(108, 99, 255, 0.15);
    transform: translateY(-2px);
  }

  .nav-link.active {
    color: #6c63ff;
    background: rgba(108, 99, 255, 0.2);
  }

  .link-icon {
    font-size: 0.9rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .btn {
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, #6c63ff, #8b5cf6);
    color: #fff;
    box-shadow: 0 4px 15px rgba(108, 99, 255, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 0.85rem;
  }

  .icon-btn {
    position: relative;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    padding: 10px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .icon-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }

  .icon-btn .icon {
    font-size: 1.2rem;
  }

  .notification-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: #ef4444;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 6px;
    border-radius: 50%;
    min-width: 18px;
    text-align: center;
  }

  .notifications-wrapper,
  .profile-wrapper {
    position: relative;
  }

  .notifications-dropdown,
  .profile-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: #1a1a2e;
    border: 1px solid rgba(108, 99, 255, 0.3);
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 1001;
  }

  .notifications-dropdown {
    width: 320px;
  }

  .profile-dropdown {
    width: 260px;
  }

  .notifications-wrapper.show .notifications-dropdown,
  .profile-wrapper.show .profile-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    font-weight: 600;
  }

  .notifications-list {
    max-height: 300px;
    overflow-y: auto;
  }

  .notification-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .notification-item:hover {
    background: rgba(108, 99, 255, 0.1);
  }

  .notification-item.unread {
    background: rgba(108, 99, 255, 0.15);
  }

  .notification-icon {
    font-size: 1.2rem;
  }

  .notification-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .notification-title {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .notification-time {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .empty-notifications {
    padding: 30px 20px;
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
  }

  .dropdown-footer {
    display: block;
    padding: 14px 20px;
    text-align: center;
    color: #6c63ff;
    text-decoration: none;
    font-weight: 500;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0 0 16px 16px;
    transition: background 0.2s ease;
  }

  .dropdown-footer:hover {
    background: rgba(108, 99, 255, 0.1);
  }

  .profile-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    padding: 8px 14px 8px 8px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .profile-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .profile-img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 99, 255, 0.5);
  }

  .profile-name {
    color: #fff;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .dropdown-arrow {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.7rem;
    transition: transform 0.3s ease;
  }

  .profile-wrapper.show .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-user {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
  }

  .dropdown-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #6c63ff;
  }

  .dropdown-user-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dropdown-username {
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
  }

  .dropdown-email {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8rem;
  }

  .dropdown-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 4px 0;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .dropdown-item:hover {
    background: rgba(108, 99, 255, 0.15);
    color: #fff;
    padding-left: 28px;
  }

  .dropdown-item.logout:hover {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .item-icon {
    font-size: 1rem;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .hamburger-line {
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 1024px) {
    .nav-links .nav-link span.link-icon {
      display: none;
    }

    .nav-link {
      padding: 10px 12px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 768px) {
    .nav-container {
      padding: 12px 20px;
    }

    .hamburger {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 70px;
      left: 0;
      right: 0;
      background: linear-gradient(180deg, #0f1322, #1a1a2e);
      flex-direction: column;
      padding: 20px;
      gap: 8px;
      max-height: calc(100vh - 70px);
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      border-top: 1px solid rgba(108, 99, 255, 0.2);
    }

    .nav-links.active {
      transform: translateX(0);
    }

    .nav-link {
      width: 100%;
      padding: 14px 20px;
      font-size: 1rem;
      border-radius: 12px;
    }

    .nav-link span.link-icon {
      display: inline;
    }

    .profile-name {
      display: none;
    }

    .dropdown-arrow {
      display: none;
    }

    .btn {
      padding: 8px 14px;
      font-size: 0.85rem;
    }

    .notifications-dropdown,
    .profile-dropdown {
      position: fixed;
      top: 70px;
      left: 20px;
      right: 20px;
      width: auto;
    }
  }
</style>

<script>
  (function() {
    const nav = document.getElementById('mainNav');
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    const notificationWrapper = document.getElementById('notificationsWrapper');
    const notificationToggle = document.getElementById('notificationToggle');
    const profileWrapper = document.getElementById('profileWrapper');
    const profileToggle = document.getElementById('profileToggle');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });

    hamburger?.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navLinks?.classList.toggle('active');
    });

    function closeDropdowns() {
      notificationWrapper?.classList.remove('show');
      profileWrapper?.classList.remove('show');
    }

    notificationToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      profileWrapper?.classList.remove('show');
      notificationWrapper?.classList.toggle('show');
    });

    profileToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      notificationWrapper?.classList.remove('show');
      profileWrapper?.classList.toggle('show');
    });

    document.addEventListener('click', (e) => {
      if (!notificationWrapper?.contains(e.target)) {
        notificationWrapper?.classList.remove('show');
      }
      if (!profileWrapper?.contains(e.target)) {
        profileWrapper?.classList.remove('show');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeDropdowns();
        hamburger?.classList.remove('active');
        navLinks?.classList.remove('active');
      }
    });
  })();
</script>