<% layout("layouts/boilerplate") %>
<link rel="stylesheet" href="/css/index.css">

<div class="spotlight"></div>

<section class="hero-section">
    <div class="hero-container">
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fa-solid fa-scale-balanced"></i>
                <span>Your Legal Companion</span>
            </div>
            <h1 class="hero-title">
                <span class="gradient-text">Clarity. Counsel.</span>
                <span class="gradient-text">Confidence.</span>
            </h1>
            <p class="hero-subtitle">
                LegalHub simplifies complex legal jargon into clear answers, connects you with verified 
                lawyers, and provides templates tailored for India.
            </p>
            <div class="hero-actions">
                <a href="/articles" class="btn btn-primary">
                    <i class="fa-solid fa-book-open"></i>
                    Explore Resources
                </a>
                <a href="/lawyers" class="btn btn-secondary">
                    <i class="fa-solid fa-user-tie"></i>
                    Find a Lawyer
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-value">250k+</div>
                    <div class="stat-label">Legal Terms</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">3.9k+</div>
                    <div class="stat-label">Verified Lawyers</div>
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div class="visual-card">
                <div class="visual-inner">
                    <div class="visual-icon">
                        <i class="fa-solid fa-gavel"></i>
                    </div>
                    <div class="visual-title">Know Your Rights</div>
                    <div class="visual-desc">Access comprehensive constitutional rights and legal resources</div>
                </div>
                <div class="visual-bar"></div>
            </div>
        </div>
    </div>
</section>

<section class="section dictionary-section">
    <div class="section-header">
        <div class="section-badge">
            <i class="fa-solid fa-book"></i>
            <span>AI-Powered Dictionary</span>
        </div>
        <h2 class="section-title">Understand Legal Terminology</h2>
        <p class="section-subtitle">
            Search our comprehensive legal dictionary powered by AI to understand complex terms and concepts.
        </p>
    </div>

    <div class="dictionary-search">
        <form id="search-form" class="dictionary-form">
            <input
                type="text"
                id="term-input"
                class="dictionary-input"
                placeholder="Search legal terms (e.g., 'habeas corpus', 'tort')..."
                required
            />
            <button type="submit" class="dictionary-btn">
                <i class="fa-solid fa-search"></i>
                Search
            </button>
        </form>
    </div>

    <div id="result" class="dictionary-result hidden">
        <div id="term-definition"></div>
    </div>
</section>

<section class="section lawyers-section">
    <div class="section-header">
        <div class="section-badge">
            <i class="fa-solid fa-user-tie"></i>
            <span>Expert Lawyers</span>
        </div>
        <h2 class="section-title">Top-Rated Legal Professionals</h2>
        <p class="section-subtitle">
            Connect with verified legal experts ready to help you with your legal matters.
        </p>
    </div>

    <div class="lawyers-grid">
        <% lawyers.forEach((lawyer, index) => { %>
        <article class="lawyer-card" style="animation-delay: <%= index * 0.1 %>s;">
            <% if (lawyer.lawyerProfile?.isVerified) { %>
            <span class="lawyer-badge">
                <i class="fas fa-check-circle"></i>
                Verified
            </span>
            <% } %>
            
            <div class="lawyer-card-header">
                <div class="lawyer-avatar-wrapper">
                    <img
                        src="<%= lawyer.photo || '/pic/profile.jpg' %>"
                        alt="<%= lawyer.name %>"
                        class="lawyer-avatar"
                    />
                    <div class="lawyer-online-indicator"></div>
                </div>
                <div class="lawyer-info">
                    <h3><%= lawyer.name %></h3>
                    <span class="lawyer-specialization">
                        <i class="fa-solid fa-briefcase"></i>
                        <%= lawyer.lawyerProfile?.specialization || 'General Practice' %>
                    </span>
                </div>
            </div>

            <div class="lawyer-rating">
                <div class="stars">
                    <% const actualRating = lawyer.lawyerProfile?.rating;
                       const rating = (typeof actualRating === 'number' && actualRating > 0) ? Math.floor(actualRating) : 5;
                       for (let i = 1; i <= 5; i++) { %>
                    <span class="star <%= i <= rating ? '' : 'empty' %>">★</span>
                    <% } %>
                </div>
                <span class="rating-value"><%= rating %> / 5</span>
            </div>

            <div class="lawyer-details">
                <div class="lawyer-detail-item">
                    <i class="fa-solid fa-clock"></i>
                    <span><%= lawyer.lawyerProfile?.experience || 'N/A' %> years</span>
                </div>
                <div class="lawyer-detail-item">
                    <i class="fa-solid fa-location-dot"></i>
                    <span><%= lawyer.lawyerProfile?.city || lawyer.lawyerProfile?.state || 'India' %></span>
                </div>
            </div>

            <div class="lawyer-tags">
                <% const specs = (lawyer.lawyerProfile?.specialization || 'General').split(',');
                   specs.slice(0, 2).forEach(spec => { %>
                <span class="lawyer-tag"><%= spec.trim() %></span>
                <% }) %>
            </div>

            <a href="/lawyers/<%= lawyer._id %>" class="lawyer-card-footer">
                <span class="lawyer-action-text">
                    <i class="fa-solid fa-calendar-check"></i>
                    Book Consultation
                </span>
                <i class="fa-solid fa-arrow-right lawyer-arrow"></i>
            </a>
        </article>
        <% }) %>
    </div>

    <div class="view-all-container">
        <a href="/lawyers" class="view-all-btn">
            View All Lawyers
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</section>

<section class="section resources-section">
    <div class="section-header">
        <div class="section-badge">
            <i class="fa-solid fa-folder"></i>
            <span>Legal Resources</span>
        </div>
        <h2 class="section-title">Complete Legal Resource Hub</h2>
        <p class="section-subtitle">
            Everything you need for legal research, documentation, and professional connections.
        </p>
    </div>

    <div class="resources-grid">
        <a href="/dictionary" class="resource-card blue">
            <div class="resource-icon">
                <i class="fa-solid fa-book"></i>
            </div>
            <span class="resource-label">Dictionary</span>
            <span class="resource-count">10K+ Terms</span>
        </a>

        <a href="/documents" class="resource-card green">
            <div class="resource-icon">
                <i class="fa-solid fa-file-lines"></i>
            </div>
            <span class="resource-label">Documents</span>
            <span class="resource-count">2.5K+ Forms</span>
        </a>

        <a href="/articles" class="resource-card purple">
            <div class="resource-icon">
                <i class="fa-solid fa-newspaper"></i>
            </div>
            <span class="resource-label">Articles</span>
            <span class="resource-count">Expert Guides</span>
        </a>

        <a href="/rights" class="resource-card red">
            <div class="resource-icon">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <span class="resource-label">Rights</span>
            <span class="resource-count">Constitutional</span>
        </a>

        <a href="#faq" class="resource-card orange">
            <div class="resource-icon">
                <i class="fa-solid fa-circle-question"></i>
            </div>
            <span class="resource-label">FAQ</span>
            <span class="resource-count">Common Answers</span>
        </a>

        <a href="/lawyers" class="resource-card indigo">
            <div class="resource-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <span class="resource-label">Lawyers</span>
            <span class="resource-count">500+ Verified</span>
        </a>
    </div>
</section>

<section class="section contributors-section">
    <div class="section-header">
        <div class="section-badge">
            <i class="fa-solid fa-heart"></i>
            <span>Community</span>
        </div>
        <h2 class="section-title">Thanks to Our Contributors</h2>
        <p class="section-subtitle">Open source community building LegalHuB</p>
    </div>

    <div class="contributors-wrapper">
        <div class="contributors-track" id="sliderTrack">
            <% if (contributorsTop && contributorsTop.length > 0) { %>
                <% contributorsTop.forEach(c => { %>
                <a href="<%= c.html_url %>" target="_blank" rel="noopener" class="contrib-card">
                    <img src="<%= c.avatar_url %>" alt="<%= c.login %>" class="contrib-avatar" />
                    <span class="contrib-name">@<%= c.login %></span>
                    <span class="contrib-count">
                        <i class="fa-solid fa-code"></i>
                        <%= c.contributions %> contributions
                    </span>
                </a>
                <% }) %>
            <% } else { %>
                <a href="https://github.com" target="_blank" rel="noopener" class="contrib-card">
                    <div class="contrib-avatar" style="background: var(--gradient-primary); display: flex; align-items: center; justify-content: center;">
                        <i class="fa-brands fa-github" style="font-size: 2rem; color: white;"></i>
                    </div>
                    <span class="contrib-name">Join Us</span>
                    <span class="contrib-count">
                        <i class="fa-solid fa-code"></i>
                        Contribute on GitHub
                    </span>
                </a>
            <% } %>
        </div>
    </div>

    <div class="view-all-container">
        <a href="/contributors" class="view-all-btn">
            View All Contributors
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</section>

<section class="section faq-section" id="faq">
    <div class="faq-container">
        <div class="faq-info">
            <div class="faq-info-header">
                <div class="section-badge">
                    <i class="fa-solid fa-circle-question"></i>
                    <span>Help Center</span>
                </div>
                <h2>Frequently Asked Questions</h2>
            </div>
            <p>Find quick answers to common legal queries. Still have questions? We're here to help.</p>
            <div class="faq-contact">
                <div class="faq-contact-icon"><i class="fa-solid fa-headset"></i></div>
                <div class="faq-contact-text">
                    <span class="faq-contact-label">Email Support</span>
                    <a href="mailto:support@legalhub.com">support@legalhub.com</a>
                </div>
            </div>
        </div>

        <div class="faq-list">
            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-scale-balanced"></i></span>
                    <span class="faq-question-text">What is LegalHub?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>LegalHub is a comprehensive legal resource platform for Indian citizens. We provide free access to legal information, state-specific forms, AI-powered dictionary, and verified lawyer connections to help you navigate the legal system.</p>
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-file-lines"></i></span>
                    <span class="faq-question-text">Can I download legal forms?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>Yes! We provide access to state-specific legal forms with detailed guidelines on how to fill them correctly. All resources are free to download and cover various departments including Revenue, Police, Court, and more.</p>
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-brain"></i></span>
                    <span class="faq-question-text">How does the AI dictionary work?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>Our AI-powered dictionary provides detailed explanations for legal terms. Simply search for any term to get comprehensive definitions, real-world examples, and related legal concepts explained in plain language.</p>
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-check-circle"></i></span>
                    <span class="faq-question-text">Is the information accurate?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>Yes. We source information from verified legal authorities and update it regularly to reflect the latest legal changes in India. Our AI helps simplify complex legal concepts while maintaining accuracy.</p>
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-indian-rupee-sign"></i></span>
                    <span class="faq-question-text">Is LegalHub completely free?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>Absolutely! LegalHub is completely free to use. You can access all resources including legal terms, forms, articles, constitutional rights, and lawyer connections without any charges.</p>
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    <span class="faq-question-icon"><i class="fa-solid fa-user-shield"></i></span>
                    <span class="faq-question-text">Are lawyers verified?</span>
                    <span class="faq-question-toggle"><i class="fa-solid fa-plus"></i></span>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        <p>Yes, all lawyers on LegalHub are verified by our team. We verify credentials, licenses, and experience before listing any lawyer on our platform.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-content">
        <h2 class="cta-title">Ready to Explore Legal Knowledge?</h2>
        <p class="cta-subtitle">
            Start your journey to understanding legal rights and resources today.
        </p>
        <div class="hero-actions" style="justify-content: center;">
            <a href="/dictionary" class="btn btn-primary">
                <i class="fa-solid fa-search"></i>
                Search Dictionary
            </a>
            <a href="/lawyers" class="btn btn-secondary">
                <i class="fa-solid fa-user-tie"></i>
                Find Lawyer
            </a>
        </div>
    </div>
</section>

<style>
    .dictionary-result.enhanced {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(99, 102, 241, 0.05));
        border: 1px solid rgba(139, 92, 246, 0.2);
        border-radius: 16px;
        padding: 2rem;
        margin-top: 1.5rem;
    }

    .term-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .term-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
    }

    .term-badge {
        background: linear-gradient(135deg, #8b5cf6, #6366f1);
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.375rem 0.875rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .term-section {
        margin-bottom: 1.5rem;
    }

    .term-section:last-child {
        margin-bottom: 0;
    }

    .section-header-content {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .section-header-content i {
        color: #a78bfa;
        font-size: 1.125rem;
    }

    .section-header-content h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        margin: 0;
    }

    .section-content p {
        color: #94a3b8;
        line-height: 1.7;
        font-size: 0.9375rem;
    }

    .example-box {
        background: rgba(255, 255, 255, 0.03);
        border-left: 3px solid #8b5cf6;
        padding: 1rem 1.25rem;
        border-radius: 0 8px 8px 0;
        margin-top: 0.75rem;
        font-style: italic;
        color: #94a3b8;
    }

    .error-message {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #fca5a5;
        padding: 1.25rem;
        border-radius: 12px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .search-loading {
        text-align: center;
        padding: 2.5rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    #result.show {
        display: block;
        animation: fadeIn 0.3s ease;
    }

    .hidden {
        display: none;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .dictionary-result {
        animation: fadeIn 0.3s ease;
    }
</style>

<script>
    const form = document.getElementById('search-form');
    const input = document.getElementById('term-input');
    const resultContainer = document.getElementById('result');
    const definition = document.getElementById('term-definition');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const term = input.value.trim();
        if (!term) return;

        definition.innerHTML = `<div class="search-loading"><i class="fa-solid fa-spinner fa-spin"></i> Searching for "${term}"...</div>`;
        resultContainer.classList.remove('hidden');
        resultContainer.classList.add('show');

        try {
            const res = await fetch(`/api/dictionary/${term}`);
            const data = await res.json();

            if (data.success) {
                let structured;
                if (data.data && data.data.structured) {
                    structured = data.data.structured;
                } else if (data.structured) {
                    structured = data.structured;
                } else {
                    structured = data.data || data;
                }

                const cleanJsonText = (text) => {
                    if (typeof text !== 'string') return text;
                    return text
                        .replace(/```json\s*/g, '')
                        .replace(/```/g, '')
                        .replace(/\\n/g, ' ')
                        .replace(/\n/g, ' ')
                        .replace(/&quot;/g, '"')
                        .replace(/&amp;/g, '&')
                        .replace(/\s+/g, ' ')
                        .trim();
                };

                if (typeof structured === 'string' && structured.trim().startsWith('{') && structured.trim().endsWith('}')) {
                    try {
                        const jsonData = JSON.parse(structured);
                        if (jsonData.isLegalTerm === false && jsonData.message) {
                            structured = { term, isLegalTerm: false, message: jsonData.message };
                        } else if (jsonData.definition) {
                            structured = { term: jsonData.term || term, definition: cleanJsonText(jsonData.definition), examples: jsonData.examples || [] };
                        } else {
                            structured = { term, definition: cleanJsonText(JSON.stringify(jsonData)) };
                        }
                    } catch (e) {
                        structured = { term, definition: cleanJsonText(structured) };
                    }
                }

                const termName = structured.term || term;
                let htmlOutput = `<div class="dictionary-result enhanced">
                    <div class="term-header">
                        <h3 class="term-name">${termName}</h3>
                        <span class="term-badge">${structured.isLegalTerm === false ? 'Info' : 'Legal Term'}</span>
                    </div>`;

                if (structured.isLegalTerm === false && structured.message) {
                    htmlOutput += `<div class="term-section">
                        <div class="section-header-content"><i class="fa-solid fa-circle-info"></i><h4>Information</h4></div>
                        <div class="section-content"><p>${cleanJsonText(structured.message)}</p></div>
                    </div>`;
                } else if (structured.definition) {
                    htmlOutput += `<div class="term-section">
                        <div class="section-header-content"><i class="fa-solid fa-book-open"></i><h4>Definition</h4></div>
                        <div class="section-content"><p>${typeof structured.definition === 'string' ? cleanJsonText(structured.definition) : cleanJsonText(structured.definition.short || structured.definition.description || 'No definition available.')}</p></div>
                    </div>`;

                    if (structured.examples && structured.examples.length > 0) {
                        const example = typeof structured.examples[0] === 'string' ? structured.examples[0] : structured.examples[0].description || '';
                        htmlOutput += `<div class="term-section">
                            <div class="section-header-content"><i class="fa-solid fa-lightbulb"></i><h4>Example</h4></div>
                            <div class="example-box">${cleanJsonText(example)}</div>
                        </div>`;
                    }
                }

                htmlOutput += `</div>`;
                definition.innerHTML = htmlOutput;
            } else {
                definition.innerHTML = `<div class="error-message"><i class="fa-solid fa-circle-exclamation"></i> ${data.msg || 'An error occurred'}</div>`;
            }
        } catch (error) {
            definition.innerHTML = `<div class="error-message"><i class="fa-solid fa-circle-exclamation"></i> Failed to fetch result. Please try again.</div>`;
        }
    });

    document.querySelectorAll('.faq-item').forEach((item) => {
        item.querySelector('.faq-question').addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
            if (!isActive) item.classList.add('active');
        });
    });
</script>