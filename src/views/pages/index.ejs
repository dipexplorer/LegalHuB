<% layout("layouts/boilerplate") %>
<link rel="stylesheet" href="/css/index.css">

<body class="home-body">
    <div class="spotlight"></div>

    <main class="hero-section">
        <div class="hero-bg-pattern"></div>
        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="badge-icon">⚖️</span>
                    <span>India's Legal Knowledge Platform</span>
                </div>
                <h1 class="hero-title reveal">
                    <span class="title-line">Clarity.</span>
                    <span class="title-line accent">Counsel.</span>
                    <span class="title-line">Confidence.</span>
                </h1>
                <p class="hero-subtitle reveal">
                    Transform complex legal jargon into clear answers. Connect with verified lawyers,
                    access state-specific documents, and understand your constitutional rights — all in one place.
                </p>
                <div class="hero-actions reveal">
                    <a href="/dictionary" class="btn btn-primary btn-lg">
                        <span class="btn-icon">📖</span> Explore Dictionary
                    </a>
                    <a href="/lawyers" class="btn btn-outline btn-lg">
                        <span class="btn-icon">👨‍⚖️</span> Find a Lawyer
                    </a>
                </div>
                <div class="hero-stats reveal">
                    <div class="stat-item">
                        <span class="stat-number">250K+</span>
                        <span class="stat-label">Legal Terms</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-number">3.9K+</span>
                        <span class="stat-label">Verified Lawyers</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-number">28+</span>
                        <span class="stat-label">States Covered</span>
                    </div>
                </div>
            </div>
            <div class="hero-visual">
                <div class="visual-container">
                    <div class="floating-card card-1">
                        <span class="card-icon">📜</span>
                        <span class="card-text">Legal Documents</span>
                    </div>
                    <div class="floating-card card-2">
                        <span class="card-icon">⚖️</span>
                        <span class="card-text">Know Your Rights</span>
                    </div>
                    <div class="floating-card card-3">
                        <span class="card-icon">💬</span>
                        <span class="card-text">Expert Consultation</span>
                    </div>
                    <div class="hero-glow"></div>
                </div>
            </div>
        </div>
        <div class="hero-scroll-indicator">
            <span>Scroll to explore</span>
            <div class="scroll-arrow">↓</div>
        </div>
    </main>

    <section class="search-section" id="searchSection">
        <div class="section-container">
            <div class="section-header">
                <h2 class="section-title reveal">
                    <span class="title-icon">🔍</span>
                    Legal Dictionary Search
                </h2>
                <p class="section-subtitle reveal">
                    Enter any legal term to get instant AI-powered explanations
                </p>
            </div>
            <div class="search-container reveal">
                <form id="search-form" class="search-form">
                    <div class="search-input-wrapper">
                        <span class="search-icon">🔎</span>
                        <input
                            type="text"
                            id="term-input"
                            class="search-input"
                            placeholder="Try 'habeas corpus', 'tort', 'custody'..."
                            required />
                        <button type="submit" id="search-button" class="search-btn">
                            <span class="btn-text">Search</span>
                            <span class="btn-loading">⏳</span>
                        </button>
                    </div>
                </form>
                <div id="result" class="search-result hidden">
                    <div class="result-header">
                        <h3 class="result-title">Result</h3>
                        <button class="result-close" id="resultClose">×</button>
                    </div>
                    <div id="term-definition" class="result-content"></div>
                </div>
            </div>
            <div class="popular-terms reveal">
                <span class="popular-label">Popular searches:</span>
                <div class="terms-list">
                    <a href="#" class="term-pill" data-term="habeas corpus">Habeas Corpus</a>
                    <a href="#" class="term-pill" data-term="bail">Bail</a>
                    <a href="#" class="term-pill" data-term="contract">Contract</a>
                    <a href="#" class="term-pill" data-term="divorce">Divorce</a>
                    <a href="#" class="term-pill" data-term="tenant rights">Tenant Rights</a>
                </div>
            </div>
        </div>
    </section>

    <section class="features-section">
        <div class="section-container">
            <div class="section-header">
                <span class="section-badge">Features</span>
                <h2 class="section-title reveal">Complete Legal Resource Hub</h2>
                <p class="section-subtitle reveal">
                    Everything you need for legal research, documentation, and professional connections
                </p>
            </div>
            <div class="features-grid">
                <a href="/dictionary" class="feature-card feature-1 reveal">
                    <div class="feature-icon">📖</div>
                    <h3 class="feature-title">Legal Dictionary</h3>
                    <p class="feature-desc">10K+ terms with AI-powered explanations</p>
                    <span class="feature-arrow">→</span>
                </a>
                <a href="/documents" class="feature-card feature-2 reveal">
                    <div class="feature-icon">📋</div>
                    <h3 class="feature-title">Legal Documents</h3>
                    <p class="feature-desc">State-wise forms and legal templates</p>
                    <span class="feature-arrow">→</span>
                </a>
                <a href="/rights" class="feature-card feature-3 reveal">
                    <div class="feature-icon">🛡️</div>
                    <h3 class="feature-title">Constitutional Rights</h3>
                    <p class="feature-desc">Know your fundamental rights</p>
                    <span class="feature-arrow">→</span>
                </a>
                <a href="/articles" class="feature-card feature-4 reveal">
                    <div class="feature-icon">📰</div>
                    <h3 class="feature-title">Articles & Guides</h3>
                    <p class="feature-desc">Expert-written legal content</p>
                    <span class="feature-arrow">→</span>
                </a>
                <a href="/lawyers" class="feature-card feature-5 reveal">
                    <div class="feature-icon">👨‍⚖️</div>
                    <h3 class="feature-title">Lawyer Directory</h3>
                    <p class="feature-desc">Connect with verified professionals</p>
                    <span class="feature-arrow">→</span>
                </a>
                <a href="/appointments" class="feature-card feature-6 reveal">
                    <div class="feature-icon">📅</div>
                    <h3 class="feature-title">Book Appointments</h3>
                    <p class="feature-desc">Schedule consultations easily</p>
                    <span class="feature-arrow">→</span>
                </a>
            </div>
        </div>
    </section>

    <section class="lawyers-section">
        <div class="section-container">
            <div class="section-header">
                <span class="section-badge">Expert Lawyers</span>
                <h2 class="section-title reveal">Top-Rated Legal Professionals</h2>
                <p class="section-subtitle reveal">Connect with verified experts across India</p>
            </div>
            <div class="lawyers-grid">
                <% lawyers.forEach((lawyer, index) => { %>
                <article class="lawyer-card reveal" style="--delay: <%= index * 0.1 %>s">
                    <div class="lawyer-badge-container">
                        <% if (lawyer.lawyerProfile?.isVerified) { %>
                        <span class="lawyer-badge verified">
                            <span class="badge-icon">✓</span> Verified
                        </span>
                        <% } else { %>
                        <span class="lawyer-badge unverified">
                            <span class="badge-icon">!</span> Pending
                        </span>
                        <% } %>
                    </div>
                    <div class="lawyer-profile">
                        <div class="lawyer-avatar-wrapper">
                            <img
                                src="<%= lawyer.profilePicture || '/pic/profile.jpg' %>"
                                alt="<%= lawyer.username %>"
                                class="lawyer-avatar" />
                            <div class="avatar-status"></div>
                        </div>
                        <div class="lawyer-info">
                            <h3 class="lawyer-name"><%= lawyer.username %></h3>
                            <p class="lawyer-spec">
                                <%= lawyer.lawyerProfile?.specialization || 'General Practice' %>
                            </p>
                            <div class="lawyer-location">
                                <span>📍</span>
                                <span><%= lawyer.lawyerProfile?.city || 'India' %>, <%= lawyer.lawyerProfile?.state || '' %></span>
                            </div>
                        </div>
                    </div>
                    <div class="lawyer-meta">
                        <div class="meta-item">
                            <span class="meta-icon">⭐</span>
                            <span class="meta-value"><%= (lawyer.lawyerProfile?.rating || 4.5).toFixed(1) %></span>
                            <span class="meta-label">Rating</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-icon">💼</span>
                            <span class="meta-value"><%= lawyer.lawyerProfile?.experience || '2' %>+</span>
                            <span class="meta-label">Years</span>
                        </div>
                    </div>
                    <div class="lawyer-actions">
                        <a href="/lawyers/<%= lawyer._id %>" class="btn btn-primary btn-block">
                            <span>📩</span> Connect Now
                        </a>
                    </div>
                </article>
                <% }) %>
            </div>
            <div class="section-cta reveal">
                <a href="/lawyers" class="btn btn-outline btn-lg">
                    View All Lawyers <span class="btn-icon">→</span>
                </a>
            </div>
        </div>
    </section>

    <section class="contributors-section">
        <div class="section-container">
            <div class="section-header">
                <span class="section-badge">Community</span>
                <h2 class="section-title reveal">Built by Contributors</h2>
                <p class="section-subtitle reveal">Open source project powered by the community</p>
            </div>
            <div class="contributors-showcase reveal">
                <div class="slider-container">
                    <div class="slider-track" id="sliderTrack"></div>
                </div>
            </div>
            <script type="application/json" id="contributorsData"><%= JSON.stringify(contributorsTop || []) %></script>
            <div class="section-cta reveal">
                <a href="/contributors" class="btn btn-outline btn-lg">
                    View All Contributors <span class="btn-icon">→</span>
                </a>
            </div>
        </div>
    </section>

    <section class="faq-section" id="faq">
        <div class="section-container">
            <div class="faq-layout">
                <div class="faq-header reveal">
                    <span class="section-badge">Help</span>
                    <h2 class="section-title">Frequently Asked Questions</h2>
                    <p class="section-subtitle">
                        Get quick answers to common legal queries
                    </p>
                    <div class="faq-contact">
                        <span class="contact-icon">💬</span>
                        <span>Have more questions?</span>
                        <a href="mailto:support@legalhub.com" class="contact-link">support@legalhub.com</a>
                    </div>
                </div>
                <div class="faq-list reveal">
                    <div class="faq-item">
                        <button class="faq-question">
                            <span class="question-text">What is LegalHuB and how does it work?</span>
                            <span class="question-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>LegalHuB is an online platform providing free access to legal resources, forms, and guides for Indian citizens. You can explore state-specific legal forms, understand legal terminology through our AI-powered dictionary, and connect with verified lawyers for expert consultation. 📖</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question">
                            <span class="question-text">Can I download legal forms from LegalHuB?</span>
                            <span class="question-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes! LegalHuB allows you to download state-specific legal forms directly from our database. Each document includes detailed guidelines on how to fill them correctly and the required supporting documents. 📄</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question">
                            <span class="question-text">How can I search for specific legal terms?</span>
                            <span class="question-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Use the smart search feature in our Legal Dictionary. Type any legal term and our AI will provide detailed explanations, examples, and related resources to help you understand. 🔍</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question">
                            <span class="question-text">Is the information on LegalHuB accurate and up-to-date?</span>
                            <span class="question-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. We source information from verified legal authorities and update it regularly. Our AI-powered dictionary and constitutional rights database are maintained by legal professionals to ensure accuracy. ✅</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question">
                            <span class="question-text">Is LegalHuB free to use?</span>
                            <span class="question-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Absolutely! LegalHuB is completely free to use. You can access all resources including the dictionary, documents, rights database, and articles without any payment. Premium features like lawyer appointments are charged by the lawyers themselves. 🎯</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>

<style>
    :root {
        --primary: #6c63ff;
        --primary-dark: #5a52d5;
        --accent: #a855f7;
        --bg-dark: #0f1322;
        --bg-card: #1a1a2e;
        --text-primary: #ffffff;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.5);
        --border: rgba(255, 255, 255, 0.1);
        --success: #22c55e;
        --warning: #f59e0b;
        --gradient-primary: linear-gradient(135deg, #6c63ff 0%, #a855f7 100%);
        --gradient-dark: linear-gradient(135deg, #0f1322 0%, #1a1a2e 100%);
    }

    .home-body {
        background: var(--gradient-dark);
        color: var(--text-primary);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
    }

    .hero-section {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 30px 80px;
        overflow: hidden;
    }

    .hero-bg-pattern {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
            radial-gradient(circle at 20% 80%, rgba(108, 99, 255, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(168, 85, 247, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .hero-container {
        max-width: 1400px;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(108, 99, 255, 0.15);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 50px;
        font-size: 0.9rem;
        color: var(--primary);
        margin-bottom: 24px;
    }

    .badge-icon {
        font-size: 1rem;
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 24px;
        letter-spacing: -1px;
    }

    .title-line {
        display: block;
    }

    .title-line.accent {
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--text-secondary);
        margin-bottom: 32px;
        max-width: 540px;
    }

    .hero-actions {
        display: flex;
        gap: 16px;
        margin-bottom: 48px;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: var(--gradient-primary);
        color: #fff;
        box-shadow: 0 8px 30px rgba(108, 99, 255, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(108, 99, 255, 0.5);
    }

    .btn-outline {
        background: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.2);
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-3px);
    }

    .btn-lg {
        padding: 16px 32px;
        font-size: 1.05rem;
    }

    .btn-icon {
        font-size: 1.1rem;
    }

    .btn-block {
        width: 100%;
        justify-content: center;
    }

    .hero-stats {
        display: flex;
        align-items: center;
        gap: 32px;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--primary);
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .stat-divider {
        width: 1px;
        height: 40px;
        background: var(--border);
    }

    .hero-visual {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .visual-container {
        position: relative;
        width: 400px;
        height: 400px;
    }

    .hero-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(108, 99, 255, 0.3) 0%, transparent 70%);
        border-radius: 50%;
        animation: pulse 4s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.8; }
    }

    .floating-card {
        position: absolute;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 24px;
        background: rgba(26, 26, 46, 0.9);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 16px;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        animation: float 6s ease-in-out infinite;
    }

    .card-1 {
        top: 20px;
        left: 20px;
        animation-delay: 0s;
    }

    .card-2 {
        top: 50%;
        right: 0;
        transform: translateY(-50%);
        animation-delay: 2s;
    }

    .card-3 {
        bottom: 40px;
        right: 60px;
        animation-delay: 4s;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    .card-2 {
        transform: translateY(-50%) translateX(0);
    }

    .card-2:hover {
        animation-play-state: paused;
    }

    .card-icon {
        font-size: 1.5rem;
    }

    .card-text {
        font-weight: 600;
        white-space: nowrap;
    }

    .hero-scroll-indicator {
        position: absolute;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        animation: bounce 2s ease-in-out infinite;
    }

    @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(10px); }
    }

    .scroll-arrow {
        font-size: 1.2rem;
    }

    .section-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 30px;
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-badge {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(108, 99, 255, 0.15);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 700;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

    .title-icon {
        font-size: 2rem;
    }

    .section-subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0 auto;
    }

    .search-section {
        padding: 100px 0;
        background: linear-gradient(180deg, transparent, rgba(108, 99, 255, 0.05), transparent);
    }

    .search-container {
        max-width: 700px;
        margin: 0 auto 40px;
    }

    .search-form {
        width: 100%;
    }

    .search-input-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px;
        background: var(--bg-card);
        border: 2px solid rgba(108, 99, 255, 0.3);
        border-radius: 16px;
        transition: all 0.3s ease;
    }

    .search-input-wrapper:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 30px rgba(108, 99, 255, 0.2);
    }

    .search-icon {
        padding-left: 16px;
        font-size: 1.3rem;
        color: var(--text-muted);
    }

    .search-input {
        flex: 1;
        background: transparent;
        border: none;
        padding: 16px;
        font-size: 1.1rem;
        color: var(--text-primary);
        outline: none;
    }

    .search-input::placeholder {
        color: var(--text-muted);
    }

    .search-btn {
        padding: 16px 32px;
        background: var(--gradient-primary);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .search-btn:hover {
        transform: scale(1.02);
        box-shadow: 0 8px 30px rgba(108, 99, 255, 0.4);
    }

    .search-btn.loading .btn-text {
        display: none;
    }

    .search-btn.loading .btn-loading {
        display: block;
    }

    .search-btn .btn-loading {
        display: none;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        100% { transform: rotate(360deg); }
    }

    .search-result {
        margin-top: 20px;
        background: var(--bg-card);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 16px;
        overflow: hidden;
        animation: slideUp 0.4s ease;
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .result-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
    }

    .result-title {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .result-close {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.1);
        border: none;
        border-radius: 8px;
