</style>

<script>
    const form = document.getElementById('search-form');
    const input = document.getElementById('term-input');
    const resultContainer = document.getElementById('result');
    const definition = document.getElementById('term-definition');
    const resultClose = document.getElementById('resultClose');

    resultClose?.addEventListener('click', () => {
        resultContainer.classList.add('hidden');
    });

    document.querySelectorAll('.term-pill').forEach(pill => {
        pill.addEventListener('click', (e) => {
            e.preventDefault();
            input.value = pill.dataset.term;
            form.dispatchEvent(new Event('submit'));
        });
    });

    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const term = input.value.trim();
        if (!term) return;

        const btn = document.getElementById('search-button');
        btn.classList.add('loading');

        definition.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--text-muted);">🔎 Searching for "' + term + '"...</div>';
        resultContainer.classList.remove('hidden');

        try {
            const res = await fetch(`/api/dictionary/${term}`);
            const data = await res.json();

            btn.classList.remove('loading');

            if (data.success) {
                let structured = data.data?.structured || data.structured || data.data || data;
                const termName = structured.term || term;
                const isLegalTerm = structured.isLegalTerm !== false;

                let html = '<div style="color: #a29bfe; font-size: 1.3rem; font-weight: 600; margin-bottom: 16px;">' + termName + '</div>';

                if (!isLegalTerm && structured.message) {
                    html += '<div style="padding: 16px; background: rgba(245, 158, 11, 0.1); border-radius: 12px; margin-bottom: 16px;">';
                    html += '<div style="color: #f59e0b; font-weight: 600; margin-bottom: 8px;">⚠️ Not a Legal Term</div>';
                    html += '<p style="color: var(--text-secondary); line-height: 1.6;">' + structured.message + '</p></div>';
                } else if (structured.definition) {
                    html += '<div style="margin-bottom: 16px;">';
                    html += '<div style="color: var(--primary); font-weight: 600; margin-bottom: 8px;">📖 Definition</div>';
                    html += '<p style="color: var(--text-secondary); line-height: 1.7;">' + structured.definition + '</p></div>';
                }

                if (structured.examples && structured.examples.length > 0) {
                    html += '<div style="padding: 16px; background: rgba(108, 99, 255, 0.1); border-left: 4px solid var(--primary); border-radius: 8px;">';
                    html += '<div style="color: var(--primary); font-weight: 600; margin-bottom: 8px;">💡 Example</div>';
                    html += '<p style="color: var(--text-secondary); font-style: italic; line-height: 1.6;">' + structured.examples[0] + '</p></div>';
                }

                definition.innerHTML = html;
            } else {
                definition.innerHTML = '<div style="padding: 20px; text-align: center; color: #ef4444;">❌ Error: ' + (data.msg || 'Something went wrong') + '</div>';
            }
        } catch (error) {
            btn.classList.remove('loading');
            definition.innerHTML = '<div style="padding: 20px; text-align: center; color: #ef4444;">❌ Failed to fetch result. Please try again later.</div>';
        }
    });

    document.querySelectorAll('.faq-item').forEach(item => {
        item.querySelector('.faq-question')?.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
            if (!isActive) item.classList.add('active');
        });
    });

    const contributors = <%- JSON.stringify(contributorsTop || []) %>;
    const track = document.getElementById('sliderTrack');
    if (track && contributors.length > 0) {
        const renderContribs = () => {
            track.innerHTML = '';
            contributors.slice(0, 10).forEach(c => {
                const card = document.createElement('a');
                card.href = c.html_url;
                card.target = '_blank';
                card.rel = 'noopener';
                card.className = 'contrib-card';
                card.innerHTML = '<img src="' + c.avatar_url + '" alt="' + c.login + '" class="contrib-avatar"/><div class="contrib-name">@' + c.login + '</div><div class="contrib-count">🧩 ' + c.contributions + '</div>';
                track.appendChild(card);
            });
        };
        renderContribs();
    }
</script>